# ─────────────────────────────────────────────────────────────
# Intent — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Arc L1 ────────────────────────────────────────────────────
ARC_RPC_URL=
ARC_CHAIN_ID=

# ── Contract Addresses ────────────────────────────────────────
INTENT_ESCROW_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
AGENT_REGISTRY_ADDRESS=
SETTLEMENT_MANAGER_ADDRESS=
EXECUTION_VALIDATOR_ADDRESS=

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://intent:intent@localhost:5432/intent
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# ── Circle USDC ───────────────────────────────────────────────
USDC_ADDRESS=

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Anthropic (AI Agents) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Observability ─────────────────────────────────────────────
OTEL_ENDPOINT=http://localhost:4317
GRAFANA_API_KEY=

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DAPP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# ── Backend Server ────────────────────────────────────────────
PORT=8080
ENV=development
LOG_LEVEL=debug